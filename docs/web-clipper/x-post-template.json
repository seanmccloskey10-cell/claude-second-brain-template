{
  "schemaVersion": "0.1.0",
  "name": "Second Brain — X Post",
  "behavior": "create",
  "triggers": ["/^https:\\/\\/(x|twitter)\\.com\\/[A-Za-z0-9_]+\\/status\\/\\d+/"],
  "noteNameFormat": "{{date|date:\"YYYY-MM-DD\"}}-x-{{title|safe_name}}",
  "path": "raw",
  "properties": [
    { "name": "title", "value": "{{title}}", "type": "text" },
    { "name": "type", "value": "raw", "type": "text" },
    { "name": "source_type", "value": "x-post", "type": "text" },
    { "name": "source_url", "value": "{{url}}", "type": "text" },
    { "name": "source_author", "value": "{{author}}", "type": "text" },
    { "name": "source_date", "value": "{{published|date:\"YYYY-MM-DD\"}}", "type": "text" },
    { "name": "ingested", "value": "{{date|date:\"YYYY-MM-DD\"}}", "type": "text" },
    { "name": "processed", "value": "false", "type": "text" },
    { "name": "trust", "value": "practitioner", "type": "text" },
    { "name": "tags", "value": "raw, x, captured-by-clipper", "type": "multitext" }
  ],
  "noteContentFormat": "# {{title}}\n\n**Author:** {{author}}\n**Posted:** {{published|date:\"YYYY-MM-DD\"}}\n**URL:** {{url}}\n\n## Post\n\n{{content}}"
}
