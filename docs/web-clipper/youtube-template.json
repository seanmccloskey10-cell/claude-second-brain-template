{
  "schemaVersion": "0.1.0",
  "name": "Second Brain — YouTube",
  "behavior": "create",
  "triggers": ["https://www.youtube.com/watch"],
  "noteNameFormat": "{{date|date:\"YYYY-MM-DD\"}}-{{title|safe_name}}",
  "path": "raw/podcasts",
  "properties": [
    { "name": "title", "value": "{{title}}", "type": "text" },
    { "name": "type", "value": "raw", "type": "text" },
    { "name": "source_type", "value": "youtube", "type": "text" },
    { "name": "source_url", "value": "{{url}}", "type": "text" },
    { "name": "source_author", "value": "{{schema:@VideoObject:author}}", "type": "text" },
    { "name": "source_date", "value": "{{published|date:\"YYYY-MM-DD\"}}", "type": "text" },
    { "name": "ingested", "value": "{{date|date:\"YYYY-MM-DD\"}}", "type": "text" },
    { "name": "processed", "value": "false", "type": "text" },
    { "name": "trust", "value": "practitioner", "type": "text" },
    { "name": "tags", "value": "raw, youtube, captured-by-clipper", "type": "multitext" }
  ],
  "noteContentFormat": "# {{title}}\n\n**Channel:** {{schema:@VideoObject:author}}\n**Published:** {{published|date:\"YYYY-MM-DD\"}}\n**Duration:** {{schema:@VideoObject:duration}}\n**URL:** {{url}}\n\n## Description\n\n{{schema:@VideoObject:description}}\n\n## Transcript\n\n{{transcript}}"
}
